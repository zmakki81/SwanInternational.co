  <title>Swan International Assistance | Flight Delay Service</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #003964;
      --fg: #FFFFFF;
      --fg-muted: rgba(255, 255, 255, 0.75);
      --accent: #008f7c;
      --btn: #008f7c;
      --border: rgba(255, 255, 255, 0.10);
      --footer-bg: #002d4f;
    }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.6;
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }

    /* Header */
    header {
      border-bottom: 1px solid var(--border);
    }
    .header-inner {
      max-width: 1152px;
      margin: 0 auto;
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }
    .logo { height: 40px; width: auto; display: block; }
    nav { display: flex; align-items: center; gap: 24px; }
    nav a {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--fg-muted);
      transition: color 0.2s;
    }
    nav a:hover { color: var(--fg); }
    .icon-btn {
      width: 36px; height: 36px;
      border: 1px solid rgba(240, 237, 232, 0.3);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: background 0.2s, border-color 0.2s;
    }
    .icon-btn:hover { background: var(--accent); border-color: var(--accent); }
    .header-right { display: flex; align-items: center; gap: 20px; }

    /* Hero */
    .hero {
      max-width: 1152px;
      margin: 0 auto;
      padding: 48px 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 32px;
      flex-wrap: wrap;
    }
    h1 {
      font-size: 36px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .subtitle {
      font-size: 30px;
      font-weight: 300;
      color: var(--fg-muted);
      margin-top: 4px;
    }
    .badges {
      display: flex;
      gap: 8px;
      margin-top: 20px;
      flex-wrap: wrap;
    }
    .badge {
      background: var(--accent);
      color: var(--fg);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 6px 14px;
      border-radius: 4px;
    }

    /* Main content */
    main {
      max-width: 1152px;
      margin: 0 auto;
      padding: 0 24px 64px;
    }
    .lead {
      font-size: 17px;
      font-weight: 600;
      line-height: 1.7;
      margin-bottom: 36px;
    }
    h2 {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--accent);
      margin-top: 32px;
      margin-bottom: 12px;
    }
    ul {
      list-style: none;
      margin-bottom: 16px;
    }
    ul li {
      font-size: 15px;
      font-weight: 300;
      line-height: 1.7;
      margin-bottom: 2px;
    }
    p.body-text {
      font-size: 15px;
      font-weight: 300;
      line-height: 1.7;
      margin-bottom: 8px;
    }

    /* Social share */
    .social-share {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 10px;
    }
    .social-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
    .social-icons {
      display: flex;
      gap: 10px;
    }

    /* Claim button */
    .claim-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--btn);
      color: var(--fg);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 10px 20px;
      border-radius: 6px;
      margin-top: 12px;
      transition: opacity 0.2s;
    }
    .claim-btn:hover { opacity: 0.85; }

    /* Footer */
    footer {
      border-top: 1px solid var(--border);
      background: var(--footer-bg);
    }
    .footer-inner {
      max-width: 1152px;
      margin: 0 auto;
      padding: 40px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      flex-wrap: wrap;
    }
    .footer-contact {
      font-size: 14px;
      font-weight: 300;
      line-height: 1.8;
    }

    @media (max-width: 640px) {
      h1 { font-size: 26px; }
      .subtitle { font-size: 22px; }
      nav { display: none; }
      .hero { padding: 32px 24px; }
      .footer-inner { justify-content: center; text-align: center; }
    }
  </style>
